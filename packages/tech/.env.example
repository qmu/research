# Credentials for the research topics' real runs (`npm run compare`,
# `npm run research -- <topic> --real`, …). Copy this file to `.env` and fill in
# the keys for the providers you want measured live. A provider whose key is
# absent is fixtured-and-flagged in the report, never presented as a live
# measurement.
#
# The fixture paths (`npm run compare:fixture`, `--fixture`) need none of these —
# they use deterministic fixture clients and are what CI runs.
#
# `.env` is gitignored; never commit a real key.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# xAI (Grok lineup, reached through the OpenAI-compatible adapter).
XAI_API_KEY=

# Perplexity Sonar — the search-native subject of the `trend-recency` topic.
# Billed per request on top of tokens; only the trend-recency real run uses it.
PERPLEXITY_API_KEY=
