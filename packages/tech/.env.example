# Credentials for the llm-model-comparison topic's real `npm run compare` run.
# Copy this file to `.env` and fill in the keys for the providers you want
# measured live. A provider whose key is absent is fixtured-and-flagged in the
# report, never presented as a live measurement.
#
# `npm run compare:fixture` needs none of these — it uses deterministic fixture
# clients and is what CI runs.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
