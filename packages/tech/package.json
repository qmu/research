{
  "name": "@qmu/research-tech",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Fundamental technical research: LLM benchmarks and architectural studies.",
  "license": "MIT",
  "author": "qmu co.,Inc.",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "tsc": "tsc --noEmit",
    "test": "tsc --noEmit && vitest --run --passWithNoTests",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "research": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-research.ts",
    "research:archive": "node --import tsx/esm src/entrypoints/archive-research-report.ts",
    "research:site": "node --import tsx/esm src/entrypoints/render-research-site.ts",
    "research:translate-report": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/translate-research-report.ts",
    "benchmark": "tsx src/entrypoints/run-llm-benchmark.ts",
    "benchmark:fixture": "tsx src/entrypoints/run-llm-benchmark.ts --fixture",
    "compare": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-llm-model-comparison.ts",
    "compare:fixture": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-llm-model-comparison.ts --fixture",
    "compare:repair": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-llm-model-comparison.ts --only-errored",
    "compare:render": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-llm-model-comparison.ts --render-latest",
    "speed": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-split-topic.ts --group speed",
    "speed:fixture": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-split-topic.ts --group speed --fixture",
    "accuracy": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-split-topic.ts --group accuracy",
    "accuracy:fixture": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-split-topic.ts --group accuracy --fixture",
    "catalog": "node --import tsx/esm src/entrypoints/run-reference-topic.ts",
    "availability": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-llm-availability.ts",
    "availability:fixture": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-llm-availability.ts --fixture",
    "availability:estimate": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-llm-availability.ts --estimate",
    "rag": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-rag-benchmark.ts",
    "rag:fixture": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-rag-benchmark.ts --fixture",
    "rag:real": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-rag-benchmark.ts --corpus scifact",
    "rag:estimate": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-rag-benchmark.ts --estimate --corpus scifact --trials 5",
    "rag:sweep": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-rag-benchmark.ts --sweep-orphans",
    "ocr": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-ocr-comparison.ts",
    "ocr:fixture": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-ocr-comparison.ts",
    "ocr:real": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-ocr-comparison.ts --real",
    "ocr:estimate": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-ocr-comparison.ts --estimate",
    "imagegen": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-image-generation.ts",
    "imagegen:fixture": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-image-generation.ts",
    "imagegen:real": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-image-generation.ts --real",
    "imagegen:estimate": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-image-generation.ts --estimate",
    "deep-research": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-deep-research.ts",
    "deep-research:fixture": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-deep-research.ts",
    "deep-research:real": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-deep-research.ts --real",
    "deep-research:estimate": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-deep-research.ts --estimate",
    "computeruse": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-computer-use.ts",
    "computeruse:fixture": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-computer-use.ts",
    "computeruse:real": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-computer-use.ts --real",
    "computeruse:estimate": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-computer-use.ts --estimate",
    "agent-vm": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-agent-vm.ts",
    "agent-vm:fixture": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-agent-vm.ts",
    "agent-vm:real": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-agent-vm.ts --real",
    "agent-vm:estimate": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-agent-vm.ts --estimate",
    "svggen": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-svg-generation.ts",
    "svggen:fixture": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-svg-generation.ts",
    "svggen:real": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-svg-generation.ts --real",
    "svggen:estimate": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-svg-generation.ts --estimate"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.18.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@anthropic-ai/bedrock-sdk": "^0.32.0",
    "@anthropic-ai/sdk": "^0.111.0",
    "@anthropic-ai/vertex-sdk": "^0.19.0",
    "@aws-sdk/client-s3vectors": "^3.1066.0",
    "@google/genai": "^2.8.0",
    "@resvg/resvg-js": "^2.6.2",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.11.1",
    "openai": "^6.43.0",
    "sqlite-vec": "^0.1.9"
  }
}
