{
  "name": "@qmu/research-tech",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Fundamental technical research: LLM benchmarks and architectural studies.",
  "license": "MIT",
  "author": "qmu co.,Inc.",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "tsc": "tsc --noEmit",
    "test": "tsc --noEmit && vitest --run --passWithNoTests",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "benchmark": "tsx src/entrypoints/run-llm-benchmark.ts",
    "benchmark:fixture": "tsx src/entrypoints/run-llm-benchmark.ts --fixture",
    "compare": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-llm-model-comparison.ts",
    "compare:fixture": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-llm-model-comparison.ts --fixture",
    "compare:repair": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-llm-model-comparison.ts --only-errored",
    "compare:render": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-llm-model-comparison.ts --render-latest",
    "availability": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-llm-availability.ts",
    "availability:fixture": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-llm-availability.ts --fixture",
    "availability:estimate": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-llm-availability.ts --estimate",
    "rag": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-rag-benchmark.ts",
    "rag:fixture": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-rag-benchmark.ts --fixture",
    "rag:real": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-rag-benchmark.ts --corpus scifact",
    "rag:estimate": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-rag-benchmark.ts --estimate --corpus scifact --trials 5",
    "rag:sweep": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-rag-benchmark.ts --sweep-orphans",
    "ocr": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-ocr-comparison.ts",
    "ocr:fixture": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-ocr-comparison.ts",
    "ocr:real": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-ocr-comparison.ts --real",
    "ocr:estimate": "node --env-file-if-exists=.env --import tsx/esm src/entrypoints/run-ocr-comparison.ts --estimate"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.18.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@aws-sdk/client-s3vectors": "^3.1066.0",
    "@google/genai": "^2.8.0",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.11.1",
    "openai": "^6.43.0",
    "sqlite-vec": "^0.1.9"
  }
}
